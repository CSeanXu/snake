<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.snake.SnakeView
        android:id="@+id/snakeView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/scoreChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:background="@drawable/score_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_label"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.10" />
        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFeatureSettings="tnum" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bestChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        android:background="@drawable/score_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="@id/scoreChip"
        app:layout_constraintBottom_toBottomOf="@id/scoreChip"
        app:layout_constraintStart_toEndOf="@id/scoreChip">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/best_label"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.10" />
        <TextView
            android:id="@+id/bestText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/accent"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFeatureSettings="tnum" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/pauseBtn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_pause"
        android:background="@drawable/icon_btn_bg"
        android:scaleType="centerInside"
        android:contentDescription="@string/pause"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/restartBtn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_restart"
        android:background="@drawable/icon_btn_bg"
        android:scaleType="centerInside"
        android:contentDescription="@string/restart"
        app:layout_constraintTop_toTopOf="@id/pauseBtn"
        app:layout_constraintBottom_toBottomOf="@id/pauseBtn"
        app:layout_constraintEnd_toStartOf="@id/pauseBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>
